# =============================================================================
#  Multi-Agent Refactoring Debate — CLOUD LLM configuration (Anthropic / Claude)
#
#  Alternative to the paper's local Ollama+Llama3 setup. Useful for comparing a
#  small local model against a larger hosted one across the experiment repos.
#
#  Usage:
#     uv sync --extra anthropic        # one-time: installs the Claude provider for CrewAI
#     cp .env.anthropic.example .env
#     # then paste your key into RD_LLM_API_KEY below
#
#  An OpenAI variant is included (commented) at the bottom — it needs no extra.
# =============================================================================

# -----------------------------------------------------------------------------
#  LLM backend — Anthropic Claude
# -----------------------------------------------------------------------------
RD_LLM_PROVIDER=anthropic

# Use the `anthropic/` prefix so LiteLLM (under CrewAI) routes correctly even for
# model names not yet in its built-in model map.
#   anthropic/claude-sonnet-4-6   -> workhorse: best speed/cost for many calls (recommended)
#   anthropic/claude-opus-4-8     -> most capable (heaviest, highest cost)
#   anthropic/claude-haiku-4-5    -> cheapest/fastest, for large sweeps
RD_LLM_MODEL=anthropic/claude-sonnet-4-6

# Your Anthropic API key (https://console.anthropic.com/). REQUIRED for this provider —
# if left blank the system safely falls back to the deterministic `heuristic` agents.
RD_LLM_API_KEY=

# Ollama base URL is ignored for cloud providers; kept for completeness.
RD_OLLAMA_BASE_URL=http://localhost:11434

# Lower temperature -> more deterministic, grounded recommendations.
RD_LLM_TEMPERATURE=0.2

# Per-agent LLM call timeout (seconds). Cloud round-trips can be slower than local.
RD_LLM_TIMEOUT=120

# -----------------------------------------------------------------------------
#  Debate protocol
# -----------------------------------------------------------------------------
# With a strong hosted model you can afford more cross-critique rounds.
RD_DEBATE_ROUNDS=2

# Judge decision weights used to arbitrate trade-offs (normalized automatically).
RD_WEIGHT_SUSTAINABILITY=0.34
RD_WEIGHT_ARCHITECTURE=0.33
RD_WEIGHT_PERFORMANCE=0.33

# -----------------------------------------------------------------------------
#  Static analysis: SonarQube (optional — leave blank to skip gracefully)
# -----------------------------------------------------------------------------
RD_SONARQUBE_URL=
RD_SONARQUBE_TOKEN=
RD_SONARQUBE_PROJECT_KEY=refactoring-debate

# -----------------------------------------------------------------------------
#  Dynamic analysis (Scalene / py-spy / cProfile) — executes the submitted code
# -----------------------------------------------------------------------------
RD_ENABLE_DYNAMIC_ANALYSIS=false
RD_DYNAMIC_TIMEOUT=30

# -----------------------------------------------------------------------------
#  REST API
# -----------------------------------------------------------------------------
RD_API_HOST=0.0.0.0
RD_API_PORT=8000
RD_RUNS_DIR=runs
RD_LOG_LEVEL=INFO

# =============================================================================
#  OpenAI variant — needs no extra (litellm bundles the SDK). Swap the three
#  provider lines at the top for these instead:
#
#     RD_LLM_PROVIDER=openai
#     RD_LLM_MODEL=openai/gpt-4o-mini
#     RD_LLM_API_KEY=sk-...        # https://platform.openai.com/api-keys
# =============================================================================
