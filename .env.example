# =============================================================================
#  Multi-Agent Refactoring Debate — configuration
#  Copy this file to `.env` and adjust. All variables are prefixed with RD_.
# =============================================================================

# -----------------------------------------------------------------------------
#  LLM backend (drives the specialist + judge agents)
# -----------------------------------------------------------------------------
# Provider: ollama | openai | anthropic | heuristic
#   - ollama     -> local models as described in the paper (Ollama + Llama3)
#   - openai     -> OpenAI-compatible API (needs RD_LLM_API_KEY)
#   - anthropic  -> Anthropic Claude API (needs RD_LLM_API_KEY)
#   - heuristic  -> NO LLM. Deterministic rule-based agents so the full
#                   pipeline runs end-to-end with zero external services.
RD_LLM_PROVIDER=ollama

# Model identifier passed to the provider. Use the `provider/model` form so
# LiteLLM (under CrewAI) routes correctly even for newer model names.
#   ollama    -> ollama/llama3                 (must be pulled: `ollama pull llama3`)
#   openai    -> openai/gpt-4o-mini
#   anthropic -> anthropic/claude-sonnet-4-6   (see .env.anthropic.example)
RD_LLM_MODEL=ollama/llama3

# Base URL for a local Ollama server.
RD_OLLAMA_BASE_URL=http://localhost:11434

# API key for cloud providers (leave blank for ollama/heuristic).
RD_LLM_API_KEY=

# Sampling temperature for agent reasoning.
RD_LLM_TEMPERATURE=0.2

# Per-agent LLM call timeout (seconds).
RD_LLM_TIMEOUT=120

# -----------------------------------------------------------------------------
#  Debate protocol
# -----------------------------------------------------------------------------
# Number of cross-critique rounds in the peer-review debate.
RD_DEBATE_ROUNDS=1

# Decision weights used by the Judge to arbitrate trade-offs (0.0 - 1.0).
RD_WEIGHT_SUSTAINABILITY=0.34
RD_WEIGHT_ARCHITECTURE=0.33
RD_WEIGHT_PERFORMANCE=0.33

# -----------------------------------------------------------------------------
#  Static analysis tools
# -----------------------------------------------------------------------------
# SonarQube is optional. Leave RD_SONARQUBE_URL blank to skip it gracefully.
# Bring a server up with `docker compose up -d sonarqube` (see docker-compose.yml).
RD_SONARQUBE_URL=
RD_SONARQUBE_TOKEN=
RD_SONARQUBE_PROJECT_KEY=refactoring-debate

# -----------------------------------------------------------------------------
#  Dynamic analysis (Scalene / py-spy / cProfile)
# -----------------------------------------------------------------------------
# Dynamic tools EXECUTE the submitted code. Disabled by default for safety.
# Only enable for code you trust (ideally inside a sandbox/container).
RD_ENABLE_DYNAMIC_ANALYSIS=false

# Wall-clock timeout (seconds) for any dynamic execution.
RD_DYNAMIC_TIMEOUT=30

# -----------------------------------------------------------------------------
#  REST API
# -----------------------------------------------------------------------------
RD_API_HOST=0.0.0.0
RD_API_PORT=8000

# Where structured debate runs are persisted (JSON). Blank disables persistence.
RD_RUNS_DIR=runs

# Logging level: DEBUG | INFO | WARNING | ERROR
RD_LOG_LEVEL=INFO
